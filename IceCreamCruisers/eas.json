{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "preview-simulator": {
      "extends": "preview",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "channel": "production",
      "node": {
        "version": "18.18.0"
      },
      "env": {
        "npm_config_production": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "steve.schofield@gmail.com",
        "appleTeamId": "S9BA8TPMCF",
        "ascAppId": "6763822249"
      }
    }
  }
}
