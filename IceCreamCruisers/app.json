{
  "expo": {
    "name": "IceCreamCruisers",
    "slug": "IceCreamCruisers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "icecreamcruisers",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.level52tech.icecreamcruisers.dev",
      "buildNumber": "4",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Your location is used to track your position during a cruise and alert you when approaching waypoints.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Your location is used to track your position during a cruise and alert you when approaching waypoints."
      }
    },
    "android": {
      "package": "com.steveschofield.icecreamcruisers",
      "versionCode": 2,
      "privacyPolicy": "https://www.level52.tech/ice-cream-cruise-events/privacy.html",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5e2af0e5-3e15-46f2-8868-e6372e5e64d7"
      }
    },
    "owner": "ice-cream-cruiser-events",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5e2af0e5-3e15-46f2-8868-e6372e5e64d7"
    }
  }
}
